# 创建完整的.gitignore文件
@"
# 虚拟环境
venv/
env/
.venv/

# Python缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# 模型文件
*.pt
*.pth
*.bin
*.ckpt
*.h5
*.onnx

# 数据文件
data/
dataset/
*.csv
*.json
*.txt

# 训练日志
logs/
runs/
*.log
checkpoints/

# IDE配置
.vscode/
.idea/
# 模型文件（太大，不上传）
qwen2.5-1.5b-instruct/
savemodel1/
*.safetensors
*.bin
*.pt
*.pth

# HuggingFace 缓存
.cache/
.lock/


# 临时文件
*.tmp
*.temp
.DS_Store
"@ | Out-File -FilePath .gitignore -Encoding utf8